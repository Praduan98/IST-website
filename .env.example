# ─── HubSpot CRM API (server-side, private app token) ─────────────────
# All forms submit to /api/hubspot which uses this token to create/update contacts.
# Create at: Settings > Integrations > Private Apps (needs crm.objects.contacts.write scope)
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_CLIENT_SECRET=

# ─── Gmail SMTP (career application emails) ──────────────────────────
# Used by /api/apply to email resumes to the careers inbox.
# Generate app password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_NAME=InsightsTap
SMTP_USER=
SMTP_PASSWORD=
CAREERS_TO_EMAIL=careers@insightstap.com
